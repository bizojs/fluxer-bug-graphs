{
	"name": "data-visualization",
	"private": true,
	"version": "0.0.1",
	"type": "module",
	"scripts": {
		"dev": "vite dev",
		"build": "vite build",
		"rebuild": "pnpm data:generate && vite build",
		"preview": "vite preview",
		"prepare": "svelte-kit sync || echo ''",
		"check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
		"check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch",
		"data:generate": "tsx src/lib/generator/index.ts",
		"data:fetch": "tsx src/lib/generator/index.ts --fetch",
		"data:process": "tsx src/lib/generator/index.ts --process"
	},
	"pnpm": {
		"onlyBuiltDependencies": [
			"@tailwindcss/oxide",
			"esbuild"
		]
	},
	"devDependencies": {
		"@fontsource-variable/inter": "^5.2.8",
		"@internationalized/date": "^3.12.0",
		"@lucide/svelte": "^1.14.0",
		"@sveltejs/kit": "^2.59.1",
		"@sveltejs/vite-plugin-svelte": "^7.0.0",
		"@tailwindcss/vite": "^4.2.2",
		"@types/d3-scale": "^4.0.9",
		"@types/d3-shape": "^3.1.8",
		"bits-ui": "^2.16.3",
		"clsx": "^2.1.1",
		"layerchart": "2.0.0-next.48",
		"shadcn-svelte": "^1.2.7",
		"svelte": "^5.55.2",
		"svelte-check": "^4.4.6",
		"tailwind-merge": "^3.5.0",
		"tailwind-variants": "^3.2.2",
		"tailwindcss": "^4.2.2",
		"tsx": "^4.21.0",
		"tw-animate-css": "^1.4.0",
		"typescript": "^6.0.2",
		"vaul-svelte": "1.0.0-next.7",
		"vite": "^8.0.7"
	},
	"dependencies": {
		"@fontsource-variable/ibm-plex-sans": "^5.2.8",
		"@sveltejs/adapter-node": "^5.5.4",
		"@types/node": "^25.7.0",
		"d3-scale": "^4.0.2",
		"d3-shape": "^3.2.0",
		"mode-watcher": "^1.1.0"
	}
}
